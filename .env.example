APP_NAME=ContrataPorto
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://localhost:8000

# CORS & Frontend URLs
FRONTEND_URL=http://localhost:5173

# Database configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=contrataporto
DB_USERNAME=root
DB_PASSWORD=

# Session & Cache configuration
# API stateless (Bearer Token) — usar 'array' em produção para não persistir sessões no banco
SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Queue & Cache
QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=

# Mail configuration (Brevo SMTP)
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="ContrataPorto"

# Cloudinary credentials
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Sanctum — domínios stateful (deixar vazio para API Bearer pura)
SANCTUM_STATEFUL_DOMAINS=
